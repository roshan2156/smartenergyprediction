# ============================================================================
# SMART ENERGY MONITOR - ENVIRONMENT CONFIGURATION
# ============================================================================

# ============================================================================
# FLASK APPLICATION CONFIGURATION
# ============================================================================
FLASK_ENV=development                    # development / production / testing
FLASK_APP=app.py                         # Main application file
FLASK_DEBUG=True                         # Enable/disable debug mode
SECRET_KEY=your-secret-key-here-12345    # Used for session security
SESSION_SECRET=your-session-secret-here  # Session encryption key

# ============================================================================
# API SERVER CONFIGURATION
# ============================================================================
API_PORT=5000                            # Port number for API
API_HOST=0.0.0.0                         # Host address (0.0.0.0 for all interfaces)
API_URL=http://localhost:5000            # Public URL of the API

# ============================================================================
# ENERGY RATES & CALCULATION
# ============================================================================
COST_PER_KWH=7                           # Electricity cost per unit (₹)
CARBON_FACTOR=0.82                       # CO2 emission per kWh (kg)
PEAK_HOUR_RATE_MULTIPLIER=1.25           # Peak hour rate multiplier
OFF_PEAK_RATE_MULTIPLIER=0.85            # Off-peak rate multiplier
PEAK_HOUR_START=18                       # Peak hour start (6 PM = 18)
PEAK_HOUR_END=22                         # Peak hour end (10 PM = 22)

# ============================================================================
# DATABASE CONFIGURATION - PRIMARY DATABASE
# ============================================================================
# For Development (SQLite - No setup required)
DATABASE_URL=sqlite:///smart_energy.db

# For Production (PostgreSQL - For Render/Heroku deployment)
# DATABASE_URL=postgresql://username:password@localhost:5432/smart_energy

# Database Pool Settings
DB_POOL_SIZE=10                          # Connection pool size
DB_POOL_RECYCLE=3600                     # Recycle connections after 1 hour
DB_POOL_TIMEOUT=30                       # Connection timeout in seconds

# ============================================================================
# MONGODB CONFIGURATION - SECONDARY DATABASE (Optional Backup)
# ============================================================================
MONGODB_ENABLED=False                    # Enable/disable MongoDB
MONGODB_URI=mongodb://localhost:27017/   # MongoDB connection string
DATABASE_NAME=smart_energy               # MongoDB database name
MONGODB_COLLECTION_USERS=users           # Users collection name
MONGODB_COLLECTION_PREDICTIONS=predictions # Predictions collection name

# ============================================================================
# CSV STORAGE CONFIGURATION (Backup Storage)
# ============================================================================
CSV_ENABLED=True                         # Enable/disable CSV storage
CSV_BACKUP_ENABLED=True                  # Enable CSV backup
USERS_CSV=data/users.csv                 # Path for users CSV
PREDICTIONS_CSV=data/predictions.csv     # Path for predictions CSV
CSV_ENCODING=utf-8                       # CSV file encoding

# ============================================================================
# ML MODEL CONFIGURATION
# ============================================================================
MODEL_PATH=models/                       # Path to models directory
ENERGY_MODEL=energy_model.pkl            # Energy prediction model
COST_MODEL=cost_model.pkl                # Cost prediction model
CARBON_MODEL=carbon_model.pkl            # Carbon emission model
PEAK_MODEL=peak_model.pkl                # Peak hour detection model
WASTE_MODEL=waste_model.pkl              # Waste detection model
SCALER_MODEL=scaler.pkl                  # Feature scaler
FEATURES_MODEL=features.pkl              # Selected features list
LABEL_ENCODERS=label_encoders.pkl        # Label encoders for categories

# ============================================================================
# FRONTEND CONFIGURATION
# ============================================================================
FRONTEND_PATH=../frontend                # Path to frontend static files
FRONTEND_URL=http://localhost:8000       # Frontend URL (for CORS)

# ============================================================================
# CORS CONFIGURATION (Cross-Origin Resource Sharing)
# ============================================================================
CORS_ORIGINS=http://localhost:3000,http://localhost:5000,http://localhost:8000
CORS_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_HEADERS=Content-Type,Authorization,X-Requested-With
CORS_ALLOW_CREDENTIALS=True

# ============================================================================
# AUTHENTICATION & SECURITY
# ============================================================================
JWT_SECRET_KEY=your-jwt-secret-key-here  # JWT token encryption key
JWT_EXPIRATION_HOURS=24                  # JWT token expiry time
BCRYPT_ROUNDS=12                         # Password hashing rounds (higher = more secure)
PASSWORD_MIN_LENGTH=8                    # Minimum password length
PASSWORD_REQUIRE_UPPERCASE=True          # Require uppercase letters
PASSWORD_REQUIRE_LOWERCASE=True          # Require lowercase letters
PASSWORD_REQUIRE_NUMBERS=True            # Require numbers
PASSWORD_REQUIRE_SPECIAL=True            # Require special characters (!@#$%^&*)

# ============================================================================
# RATE LIMITING (Prevent API abuse)
# ============================================================================
RATE_LIMIT_ENABLED=False                 # Enable/disable rate limiting
RATE_LIMIT_PER_MINUTE=60                 # Maximum requests per minute
RATE_LIMIT_PER_HOUR=1000                 # Maximum requests per hour
RATE_LIMIT_PER_DAY=10000                 # Maximum requests per day

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================
LOG_LEVEL=INFO                           # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FILE=logs/app.log                    # Log file path
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
LOG_MAX_BYTES=10485760                   # Max log file size (10 MB)
LOG_BACKUP_COUNT=5                       # Number of backup log files

# ============================================================================
# EMAIL CONFIGURATION (For Password Reset & Alerts)
# ============================================================================
MAIL_SERVER=smtp.gmail.com               # SMTP server
MAIL_PORT=587                            # SMTP port
MAIL_USE_TLS=True                        # Use TLS encryption
MAIL_USE_SSL=False                       # Use SSL encryption
MAIL_USERNAME=your-email@gmail.com       # Email username
MAIL_PASSWORD=your-app-password          # Email password or app-specific password
MAIL_DEFAULT_SENDER=noreply@smartenergy.com
MAIL_ADMIN=admin@smartenergy.com

# ============================================================================
# ALERT CONFIGURATION
# ============================================================================
ALERTS_ENABLED=True                      # Enable/disable alerts
ALERT_EMAIL_ENABLED=False                # Email alerts
ALERT_SMS_ENABLED=False                  # SMS alerts (via Twilio)
ALERT_PUSH_ENABLED=False                 # Push notifications

# Alert Thresholds
HIGH_USAGE_THRESHOLD=5                   # kWh threshold for high usage alert
VERY_HIGH_USAGE_THRESHOLD=8              # kWh threshold for very high usage alert
WASTE_DETECTION_THRESHOLD=0.5            # Waste detection threshold (kWh)
VACANT_WASTE_THRESHOLD=0.5               # Vacant waste detection threshold

# ============================================================================
# PREDICTION CONFIGURATION
# ============================================================================
PREDICTION_BATCH_SIZE=100                # Batch size for batch predictions
FORECAST_DAYS=7,30,365                   # Available forecast periods (days)
MIN_PREDICTION_CONFIDENCE=0.85           # Minimum confidence for prediction
PREDICTION_CACHE_ENABLED=True            # Cache predictions
PREDICTION_CACHE_TIMEOUT=300             # Cache timeout (seconds)

# ============================================================================
# DASHBOARD CONFIGURATION
# ============================================================================
DASHBOARD_REFRESH_INTERVAL=30            # Dashboard refresh interval (seconds)
CHARTS_ENABLED=True                      # Enable/disable charts
REAL_TIME_UPDATES=True                   # Enable real-time updates
MAX_CHART_DATA_POINTS=30                 # Maximum data points in charts

# ============================================================================
# REPORT CONFIGURATION
# ============================================================================
REPORT_GENERATION_ENABLED=True           # Enable report generation
REPORT_FORMATS=pdf,csv,txt               # Supported report formats
REPORT_STORAGE_PATH=reports/             # Path to save reports
REPORT_RETENTION_DAYS=30                 # Days to keep reports

# ============================================================================
# WASTE DETECTION CONFIGURATION
# ============================================================================
WASTE_DETECTION_ENABLED=True             # Enable waste detection
IDLE_TIME_THRESHOLD=180                  # Idle time threshold (minutes)
VACANT_OCCUPANCY_DETECTION=True          # Detect waste when vacant
APPliance_WASTE_DETECTION=True           # Detect appliance-specific waste

# ============================================================================
# CACHING CONFIGURATION (Redis - Optional)
# ============================================================================
CACHE_ENABLED=False                      # Enable Redis caching
CACHE_TYPE=redis                         # Cache type (redis, simple, filesystem)
CACHE_REDIS_URL=redis://localhost:6379/0 # Redis connection URL
CACHE_TIMEOUT=300                        # Cache timeout (seconds)
CACHE_KEY_PREFIX=smart_energy_           # Cache key prefix

# ============================================================================
# PERFORMANCE OPTIMIZATION
# ============================================================================
ASYNC_ENABLED=False                      # Enable async processing
WORKER_THREADS=4                         # Number of worker threads
REQUEST_TIMEOUT=30                       # Request timeout (seconds)
MAX_UPLOAD_SIZE=16777216                 # Max file upload size (16 MB)

# ============================================================================
# DEPLOYMENT CONFIGURATION (Render/Heroku)
# ============================================================================
# Uncomment these for production deployment
# DATABASE_URL=postgresql://user:password@host:5432/database
# MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/
# SECRET_KEY=your-very-strong-secret-key
# FLASK_ENV=production
# FLASK_DEBUG=False
# SESSION_COOKIE_SECURE=True
# SESSION_COOKIE_HTTPONLY=True
# CSRF_ENABLED=True

# ============================================================================
# TWILIO SMS CONFIGURATION (For SMS Alerts)
# ============================================================================
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE_NUMBER=+1234567890

# ============================================================================
# GOOGLE ANALYTICS (Optional)
# ============================================================================
GOOGLE_ANALYTICS_ID=UA-XXXXXXXXX-X

# ============================================================================
# FEATURE FLAGS
# ============================================================================
FEATURE_CSV_UPLOAD=True                  # Enable CSV upload feature
FEATURE_MANUAL_INPUT=True                # Enable manual input feature
FEATURE_AI_ASSISTANT=True                # Enable AI assistant feature
FEATURE_REPORTS=True                     # Enable reports feature
FEATURE_HISTORY=True                     # Enable history feature
FEATURE_FORECAST=True                    # Enable forecast feature

# ============================================================================
# DEFAULT VALUES
# ============================================================================
DEFAULT_TEMPERATURE=24                   # Default AC temperature (°C)
DEFAULT_DURATION=60                      # Default usage duration (minutes)
DEFAULT_OCCUPANCY=Occupied               # Default occupancy status
DEFAULT_APPLIANCE=Fan                    # Default appliance type
DEFAULT_ROOM=Living Room                 # Default room location

# ============================================================================
# ERROR HANDLING
# ============================================================================
ERROR_REPORTING_ENABLED=True             # Enable error reporting
ERROR_REPORT_EMAIL=errors@smartenergy.com
SHOW_ERROR_DETAILS=False                 # Show error details to users (disable in prod)

# ============================================================================
# INTERNATIONALIZATION (i18n)
# ============================================================================
DEFAULT_LANGUAGE=en                      # Default language
SUPPORTED_LANGUAGES=en,hi,gu             # Supported languages